            { initials: 'AK', name: 'Arsam Khan', rating: '★ 4.9', offer: 'Full-Stack Next.js Node Optimization', need: 'Advanced Mathematical Deep Learning Architecture Models', background: 'linear-gradient(135deg, #1B3A6B, #0D7377)' },
            { initials: 'SY', name: 'Sarah Yasmin', rating: '★ 4.8', offer: 'Cinematic Creative Storyboard Photography', need: 'Executive Corporate Keynote Communication Speaking', background: 'linear-gradient(135deg, #0D7377, #00CED1)' },
            { initials: 'MZ', name: 'Muhammad Zain', rating: '★ 5.0', offer: 'Quantitative High-Frequency System Cryptofinance', need: 'Advanced Mandarin Fluency & Structural Translation', background: 'linear-gradient(135deg, #061228, #1B3A6B)' },
            { initials: 'AA', name: 'Ayesha Ahmed', rating: '★ 4.9', offer: 'Design System Typography Figma Component Interfaces', need: 'Artificial Intelligence Neural Generative Model Frameworks', background: 'linear-gradient(135deg, #F4D03F, #0D7377)' },
            { initials: 'HL', name: 'Hamza Liaqat', rating: '★ 4.7', offer: 'Growth Engine Funnel Conversion Performance Marketing', need: 'React Core Engine Fiber Lifecycle Architecture', background: 'linear-gradient(135deg, #1E8449, #00CED1)' }
        ];
        let currentProfileIndex = 0;

        /* --- IMMUTABLE SYSTEM STARTER TRIGGERS --- */
        document.addEventListener('DOMContentLoaded', () => {
            initializeCustomCursor();
            initializeLampEntrance();
            initializeHeroCanvasNetwork();
            initializeScrollAnimations();
            initializeGalaxyConnections();
            runMatchSimulation();
            initializeTagInputSystem('teach-tags-container', 'teach-tag-field');
            initializeTagInputSystem('learn-tags-container', 'learn-tag-field');
        });

        /* --- CUSTOM RENDERER CURSOR SYSTEM --- */
        function initializeCustomCursor() {
            const cursor = document.getElementById('custom-cursor');
            document.addEventListener('mousemove', (e) => {
                cursor.style.left = e.clientX + 'px';
                cursor.style.top = e.clientY + 'px';
            });
            document.querySelectorAll('a, button, select, input, .galaxy-node-card, .carousel-arrow, .toggle-switch, .auth-tab-btn').forEach(elem => {
                elem.addEventListener('mouseenter', () => cursor.classList.add('hovered'));
                elem.addEventListener('mouseleave', () => cursor.classList.remove('hovered'));
            });
        }

        /* --- LIQUID GLASS RIPPLE PHYSICS EFFECT --- */
        document.querySelectorAll('.btn-liquid').forEach(btn => {
            btn.addEventListener('mousemove', (e) => {
                const rect = btn.getBoundingClientRect();
                const x = ((e.clientX - rect.left) / rect.width) * 100;
                const y = ((e.clientY - rect.top) / rect.height) * 100;
                btn.style.setProperty('--ripple-x', `${x}%`);
                btn.style.setProperty('--ripple-y', `${y}%`);
            });
        });

        /* --- LAMP ENTRANCE STAGE ACTIVATE --- */
        function initializeLampEntrance() {
            setTimeout(() => {
                const spotlight = document.getElementById('hero-spotlight');
                const leftContent = document.getElementById('hero-left-content');
                if(spotlight) spotlight.classList.add('on');
                if(leftContent) leftContent.classList.add('on');
                
                // Character split presentation animation
                const togetherWord = document.getElementById('split-together');
                if (togetherWord) {
                    const txt = togetherWord.innerText;
                    togetherWord.innerHTML = '';
                    txt.split('').forEach((char, i) => {
                        const span = document.createElement('span');
                        span.innerText = char;
                        span.style.transitionDelay = `${1200 + (i * 60)}ms`;
                        togetherWord.appendChild(span);
                        setTimeout(() => span.style.opacity = '1', 50);
                        setTimeout(() => span.style.transform = 'translateY(0)', 50);
                    });
                }
            }, 200);
        }

        /* --- VANILLA INTERACTION CANVAS NETWORK ENGINE --- */
        function initializeHeroCanvasNetwork() {
            const canvas = document.getElementById('hero-network-canvas');
            if(!canvas) return;
            const ctx = canvas.getContext('2d');
            let animationFrameId;

            function resize() {
                const rect = canvas.parentElement.getBoundingClientRect();
                canvas.width = rect.width;
                canvas.height = 450;
            }
            resize();

            const nodes = [];
            const labels = ["React", "Rust", "Figma", "Python", "Solidity", "AI Models", "SEO Strategy", "Mandarin"];
            for (let i = 0; i < 35; i++) {
                nodes.push({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    vx: (Math.random() - 0.5) * 0.6,
                    vy: (Math.random() - 0.5) * 0.6,
                    radius: Math.random() * 3 + 2,
                    label: i < labels.length ? labels[i] : null
                });
            }

            function draw() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                ctx.fillStyle = "rgba(0, 206, 209, 0.15)";
                ctx.strokeStyle = "rgba(13, 115, 119, 0.08)";

                // Draw vectors
                for (let i = 0; i < nodes.length; i++) {
                    for (let j = i + 1; j < nodes.length; j++) {
                        const dist = Math.hypot(nodes[i].x - nodes[j].x, nodes[i].y - nodes[j].y);
                        if (dist < 110) {
                            ctx.beginPath();
                            ctx.moveTo(nodes[i].x, nodes[i].y);
                            ctx.lineTo(nodes[j].x, nodes[j].y);
                            ctx.stroke();
                        }
                    }
                }

                // Render components
                nodes.forEach(node => {
                    node.x += node.vx;
                    node.y += node.vy;

                    if (node.x < 0 || node.x > canvas.width) node.vx *= -1;
                    if (node.y < 0 || node.y > canvas.height) node.vy *= -1;

                    ctx.beginPath();
                    ctx.arc(node.x, node.y, node.radius, 0, Math.PI * 2);
                    ctx.fillStyle = node.label ? "#00CED1" : "rgba(27, 58, 107, 0.5)";
                    ctx.fill();

                    if (node.label) {
                        ctx.fillStyle = "rgba(255,255,255,0.6)";
                        ctx.font = "10px Inter";
                        ctx.fillText(node.label, node.x + 8, node.y + 4);
                    }
                });

                animationFrameId = requestAnimationFrame(draw);
            }
            draw();
        }

        /* --- SCROLL REVEALS & COMPOSITE OBSERVERS --- */
        function initializeScrollAnimations() {
            const options = { threshold: 0.15, rootMargin: "0px 0px -50px 0px" };
            
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('revealed');
                        
                        // Count mechanics allocation hook triggers
                        if(entry.target.classList.contains('stat-item') || entry.target.classList.contains('impact-num') || entry.target.id === 'live-credit-counter') {
                            triggerCountAnimation(entry.target);
                        }
                        
                        // Gamification progress fillers
                        if(entry.target.id === 'trust-fill-bar') {
                            entry.target.style.width = '98%';
                            setTimeout(() => {
                                document.getElementById('level-toast').classList.add('show');
                                triggerSparkleBurst({clientX: window.innerWidth - 100, clientY: window.innerHeight - 100});
                                setTimeout(() => document.getElementById('level-toast').classList.remove('show'), 4000);
                            }, 1000);
                        }

                        if(entry.target.id === 'scroll-progress-ring') {
                            entry.target.style.strokeDashoffset = '70'; 
                        }

                        if(entry.target.id === 'orbital-container') {
                            deployOrbitalNodes();
                        }
                    }
                });
            }, options);

            // Register nodes array objects to pipeline tracking context
            document.querySelectorAll('.reveal-card, .trust-layer-row, .stat-num, .impact-num').forEach(el => observer.observe(el));
            
            const trustBar = document.getElementById('trust-fill-bar');
            if(trustBar) observer.observe(trustBar);
            
            const progressRing = document.getElementById('scroll-progress-ring');
            if(progressRing) observer.observe(progressRing);

            const orbitalWrap = document.getElementById('orbital-container');
            if(orbitalWrap) observer.observe(orbitalWrap);

            // Translucency configuration track context mapping trigger checks
            window.addEventListener('scroll', () => {
                const nav = document.getElementById('navbar');
                if (window.scrollY > 80) nav.classList.add('scrolled');
                else nav.classList.remove('scrolled');
            });
        }

        /* --- NUMERICAL VECTOR ACCELERATOR (COUNT-UP) --- */
        function triggerCountAnimation(element) {
            const targetEl = element.classList.contains('stat-num') || element.classList.contains('impact-num') ? element : element;
            const target = parseInt(targetEl.getAttribute('data-target') || targetEl.innerText.replace(/,/g,''));
            if(isNaN(target)) return;
            
            let current = 0;
            const duration = 2000;
            const stepTime = Math.max(Math.floor(duration / target), 12);
            const increment = Math.ceil(target / (duration / stepTime));

            const timer = setInterval(() => {
                current += increment;
                if (current >= target) {
                    targetEl.innerText = target.toLocaleString() + (targetEl.innerText.includes('+') ? '+' : '');
                    clearInterval(timer);
                } else {
                    targetEl.innerText = current.toLocaleString();
                }
            }, stepTime);
        }

        /* --- 3D PERSPECTIVE TILT MECHANICAL LOGIC HANDLERS --- */
        document.querySelectorAll('.tilt-card').forEach(card => {
            card.addEventListener('mousemove', (e) => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                
                const xc = rect.width / 2;
                const yc = rect.height / 2;
                
                const tiltX = (yc - y) / 14;
                const tiltY = (x - xc) / 14;
                
                card.style.transform = `perspective(1000px) rotateX(${tiltX}deg) rotateY(${tiltY}deg)`;
                card.style.setProperty('--glare-x', `${(x / rect.width) * 100}%`);
                card.style.setProperty('--glare-y', `${(y / rect.height) * 100}%`);
                
                const inner = card.querySelector('.tilt-card-inner');
                if(inner) inner.style.transform = `translateZ(30px) translateX(${(x - xc)/20}px) translateY(${(y - yc)/20}px)`;
            });

            card.addEventListener('mouseleave', () => {
                card.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg)';
                const inner = card.querySelector('.tilt-card-inner');
                if(inner) inner.style.transform = 'translateZ(0px) translateX(0px) translateY(0px)';
            });
        });

        /* --- GALAXY SVG VECTOR MATRIX CONNECTOR GENERATOR --- */
        function initializeGalaxyConnections() {
            const svg = document.getElementById('galaxy-svg-canvas');
            const wrap = document.getElementById('galaxy-nodes-wrap');
            if(!svg || !wrap) return;

            setTimeout(() => {
                svg.innerHTML = '';
                const nodes = wrap.querySelectorAll('.galaxy-node');
                const coords = [];

                nodes.forEach(node => {
                    coords.push({
                        x: node.offsetLeft + (node.offsetWidth / 2),
                        y: node.offsetTop + (node.offsetHeight / 2),
                        el: node
                    });
                });

                // Generate vector path maps optimization logic loops
                for(let i=0; i<coords.length; i++) {
                    for(let j=i+1; j<coords.length; j++) {
                        const dist = Math.hypot(coords[i].x - coords[j].x, coords[i].y - coords[j].y);
                        if(dist < 320) {
                            const line = document.createElementNS("http://www.w3.org/2000/svg", "line");
                            line.setAttribute("x1", coords[i].x);
                            line.setAttribute("y1", coords[i].y);
                            line.setAttribute("x2", coords[j].x);
                            line.setAttribute("y2", coords[j].y);
                            line.setAttribute("class", "galaxy-edge drawn");
                            svg.appendChild(line);
                        }
                    }
                }
            }, 600);

            // Register specific event listener arrays onto galaxy node components
            wrap.querySelectorAll('.galaxy-node-card').forEach(card => {
                card.addEventListener('click', () => {
                    const title = card.querySelector('h4').innerText;
                    filterGalaxyView(title);
                });
            });
        }

        function filterGalaxyView(categoryTitle) {
            document.getElementById('galaxy-nodes-wrap').style.display = 'none';
            const targetBox = document.getElementById('galaxy-filtered-display');
            targetBox.style.display = 'block';
            document.getElementById('filtered-galaxy-title').innerText = `${categoryTitle} Expert Exchange Hub`;

            const container = document.getElementById('filtered-mentor-cards-box');
            container.innerHTML = '';

            // Map and spawn dynamic mock configurations down onto filtered layout grid vectors
            MOCK_PROFILES.forEach((p, idx) => {
                const mCard = document.createElement('div');
                mCard.className = 'mentor-card reveal-card revealed';
                mCard.innerHTML = `
                    <div class="mentor-top">
                        <div class="mentor-avatar-container">
                            <div class="mentor-avatar-ring"></div>
                            <div class="mentor-avatar" style="background: ${p.background}"></div>
                        </div>
                        <h3>${p.name}</h3>
                        <p class="mentor-title">Instructional Node Leader</p>
                        <div class="mentor-stats-mini">${p.rating} · Active Loop Node</div>
                        <p style="font-size:0.85rem; color:white; margin-bottom:1rem;"><strong>Offers:</strong> ${p.offer}</p>
                    </div>
                    <button class="btn-liquid" onclick="openAuthModal('signup')">Connect Node Match</button>
                `;
                container.appendChild(mCard);
            });
        }

        function resetGalaxyView() {
            document.getElementById('galaxy-filtered-display').style.display = 'none';
            document.getElementById('galaxy-nodes-wrap').style.display = 'flex';
            initializeGalaxyConnections();
        }

        /* --- ORBITAL DEPLOYMENT TRIGGERS PATH MATH --- */
        function deployOrbitalNodes() {
            const nodes = document.querySelectorAll('.orbital-node');
            const centerWidth = 580 / 2;
            
            nodes.forEach(node => {
                const idx = parseInt(node.getAttribute('data-index'));
                const angle = (idx * (360 / 6)) * (Math.PI / 180);
                
                const x = centerWidth + (centerWidth * Math.cos(angle));
                const y = centerWidth + (centerWidth * Math.sin(angle));
                
                node.style.left = `${x}px`;
                node.style.top = `${y}px`;
                node.classList.add('deployed');

                // Bind custom display synchronization loops onto nodes element vectors
                node.addEventListener('mouseenter', () => activateOrbitalStep(idx));
            });

            activateOrbitalStep(0);
        }

        function activateOrbitalStep(index) {
            document.querySelectorAll('.orbital-node').forEach(n => n.classList.remove('active'));
            document.querySelectorAll('.orbital-desc-card').forEach(c => c.classList.remove('visible'));

            const activeNode = document.querySelector(`.orbital-node[data-index='${index}']`);
            const activeCard = document.querySelector(`.orbital-desc-card[data-index='${index}']`);

            if(activeNode) activeNode.classList.add('active');
            if(activeCard) {
                activeCard.classList.add('visible');
                activeCard.style.left = activeNode.style.left;
                activeCard.style.top = activeNode.style.top;
            }
        }

        /* --- MATCH MACHINE ENGINE SIMULATOR SIMULATION INTERFACES --- */
        function runMatchSimulation() {
            const flipper = document.getElementById('profile-card-flipper');
            if(!flipper) return;

            flipper.classList.add('flipped');
            
            setTimeout(() => {
                const profile = MOCK_PROFILES[currentProfileIndex];
                const content = document.getElementById('match-card-content');
                
                content.innerHTML = `
                    <div class="profile-meta">
                        <div class="profile-avatar" style="background: ${profile.background}">${profile.initials}</div>
                        <div class="profile-info">
                            <h4>${profile.name}</h4>
                            <div class="profile-rating">${profile.rating} Verified Match Integrity</div>
                        </div>
                    </div>
                    <div class="profile-exchanges">
                        <div>
                            <div class="exch-label">Provides Instruction</div>
                            <div class="exch-val">${profile.offer}</div>
                        </div>
                        <div>
                            <div class="exch-label">Acquisition Goal</div>
                            <div class="exch-val">${profile.need}</div>
                        </div>
                    </div>
                    <button class="btn-liquid" onclick="openAuthModal('signup')" style="width:100%;">Initiate Exchange Protocol Connection</button>
                `;
                flipper.classList.remove('flipped');
            }, 300);
        }

        function cycleMatchProfile(direction) {
            currentProfileIndex = (currentProfileIndex + direction + MOCK_PROFILES.length) % MOCK_PROFILES.length;
            runMatchSimulation();
        }

        /* --- IMMUTABLE SPARKLE BURST ENGINE GENERATOR --- */
        function triggerSparkleBurst(e) {
            const count = 12;
            for (let i = 0; i < count; i++) {
                const particle = document.createElement('div');
                particle.className = 'sparkle-particle';
                document.body.appendChild(particle);

                const x = e.clientX || e.x || window.innerWidth / 2;
                const y = e.clientY || e.y || window.innerHeight / 2;

                particle.style.left = x + 'px';
                particle.style.top = y + 'px';

                const angle = Math.random() * Math.PI * 2;
                const speed = Math.random() * 4 + 2;
                const destX = Math.cos(angle) * speed * 25;
                const destY = Math.sin(angle) * speed * 25;

                particle.animate([
                    { transform: 'translate(0, 0) scale(1)', opacity: 1 },
                    { transform: `translate(${destX}px, ${destY}px) scale(0)`, opacity: 0 }
                ], {
                    duration: 600,
                    easing: 'cubic-bezier(0.1, 0.8, 0.25, 1)',
                    fill: 'forwards'
                });

                setTimeout(() => particle.remove(), 600);
            }
        }
        document.addEventListener('click', (e) => {
            if(e.target.classList.contains('btn-liquid') || e.target.classList.contains('auth-tab-btn')) {
                triggerSparkleBurst(e);
            }
        });

        /* --- AUTH FLOW CONTROL OVERLAY PARSING SYSTEM --- */
        function openAuthModal(mode) {
            const overlay = document.getElementById('auth-modal-overlay');
            overlay.classList.add('active');
            switchAuthTab(mode);
        }

        function closeAuthModal() {
            document.getElementById('auth-modal-overlay').classList.remove('active');
        }

        function switchAuthTab(mode) {
            const slider = document.getElementById('auth-form-slider');
            const indicator = document.getElementById('auth-tab-indicator');
            const btnLogin = document.getElementById('tab-btn-login');
            const btnSignup = document.getElementById('tab-btn-signup');

            if (mode === 'login') {
                slider.style.transform = 'translateX(0%)';
                indicator.style.transform = 'translateX(0%)';
                btnLogin.classList.add('active');
                btnSignup.classList.remove('active');
            } else {
                slider.style.transform = 'translateX(-50%)';
                indicator.style.transform = 'translateX(100%)';
                btnSignup.classList.add('active');
                btnLogin.classList.remove('active');
            }
        }

        /* --- DYNAMIC STRUCTURAL TAG INPUT ARRAYS METRICS --- */
        function initializeTagInputSystem(containerId, fieldId) {
            const container = document.getElementById(containerId);
            const input = document.getElementById(fieldId);
            const tagStore = [];

            if(!container || !input) return;

            input.addEventListener('keydown', (e) => {
                if (e.key === 'Enter' || e.key === ',') {
                    e.preventDefault();
                    const tagValue = input.value.trim().replace(/,/g, '');
                    
                    if (tagValue && tagStore.length < 5 && !tagStore.includes(tagValue)) {
                        tagStore.push(tagValue);
                        
                        const pill = document.createElement('div');
                        pill.className = 'tag-pill';
                        pill.innerHTML = `<span>${tagValue}</span><span class="close">×</span>`;
                        
                        pill.querySelector('.close').addEventListener('click', () => {
                            pill.remove();
                            const index = tagStore.indexOf(tagValue);
                            if (index > -1) tagStore.splice(index, 1);
                        });

                        container.insertBefore(pill, input);
                        input.value = '';
                        triggerSparkleBurst(e);
                    }
                }
            });
        }

        /* --- ASYMMETRIC REAL-TIME ACCREDITATION FORM HANDLING OVERRIDES --- */
        function handleAuthSubmit(e) {
            e.preventDefault();
            const form = e.target;
            const submitBtn = form.querySelector('.btn-submit-auth');
            
            submitBtn.classList.add('loading');
            submitBtn.disabled = true;

            setTimeout(() => {
                submitBtn.classList.remove('loading');
                submitBtn.classList.add('success');
                submitBtn.querySelector('span').innerText = 'Access Sequence Allowed';
                
                // Pop visual coin metric increments onto counter interfaces
                const counter = document.getElementById('live-credit-counter');
                setTimeout(() => {
                    if(counter) {
                        counter.classList.add('pop');
                        counter.innerText = "2,550";
                        counter.style.color = "var(--electric)";
                        setTimeout(() => {
                            counter.classList.remove('pop');
                            counter.style.color = "var(--yellow)";
                        }, 400);
                    }
                    closeAuthModal();
                    submitBtn.classList.remove('success');
                    submitBtn.disabled = false;
                    submitBtn.querySelector('span').innerText = form.id.includes('login') ? 'Initialize Verification Access' : 'Register Account Vault Node';
                }, 1000);

            }, 1800);
        }

        /* --- MOBILE HAMBURGER LAYER SLIDER NAVIGATION --- */
        function toggleMobileMenu() {
            document.getElementById('hamburger').classList.toggle('open');
            document.getElementById('nav-links').classList.toggle('open');
        }
    </script>
</body>
</html>